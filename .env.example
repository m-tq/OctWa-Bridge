# Infura API key for Ethereum RPC (eth_call, eth_getBalance, etc.)
VITE_INFURA_API_KEY=your_infura_api_key_here

# Octra RPC endpoint — MUST be HTTPS when deployed on HTTPS
# Use Nginx reverse proxy: https://bridge.octwa.pw/rpc → http://46.101.86.250:8080/rpc
# See README.md for Nginx config
VITE_OCTRA_RPC=https://bridge.octwa.pw
